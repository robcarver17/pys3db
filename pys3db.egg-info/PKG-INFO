Yet another way to wrap SQQLITE3* so you don't need to learn SQL.

* other databases are available and could be used

Are you fed up with writing boilerplate SQL? Would you rather write frankly ugly chained python like `list_of_filters=[is_in('name',['ford','vw']), OR, is_equal('available',True)]`?
Are the limited number of types available in Sqllite3 bothering you? Are you suspicous of new fangled nonsense like ORM database wrappers? Then pys3db is for you!

Quick example, see [example.py](example.py) for more.

```
from dataclasses import dataclass
import datetime
from enum import Enum

from filters import *

from pydb import PyDb
from db_connection import DbConnection
from table import  create_table_for_conforming_dataclass
from translators import  get_translator_for_conforming_dataclass

Colour=Enum('colour', ['red','green','blue'])

@dataclass
class Car:
    name: str
    price: float
    quantity: int
    when_issued: datetime.date
    when_sold: datetime.datetime
    available: bool
    colour: Colour = Colour.red

dbc = DbConnection("temp.sql")
translators = get_translator_for_conforming_dataclass(Car)

table = create_table_for_conforming_dataclass(conforming_dataclass=Car, table_name="cars",
                  index_on_field_names=['name', 'available'],
                    unique_index=True) ## indexing is optional

db = PyDb(db_connection=dbc, table=table, translators=translators)


car_a = Car('ford', 2000.0, 50, when_issued=datetime.date(2025,1,1),
            when_sold=datetime.datetime(2026,1,1, 12,4), available=False
               )
db.add_item(car_a)
db.read_list_of_objects(list_of_filters=[is_in('name',['ford','vw']), OR, is_equal('available',True)], sort_by_field_list='name')
db.update_item(update_dict_with_original_types=dict(price=2000.0), list_of_filters=is_equal('name', 'ford'))
db.delete_items(is_equal('name', 'ford'))

```
